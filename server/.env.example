# PaiResume 后端配置示例
# 复制为 .env 并修改

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=pai_resume
MYSQL_USERNAME=root
MYSQL_PASSWORD=your_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT（请替换为随机 Base64 字符串，至少 32 字节）
JWT_SECRET=

# Deepseek AI
DEEPSEEK_API_KEY=your_deepseek_api_key

# 邮件
MAIL_USERNAME=your_email@qq.com
MAIL_PASSWORD=your_smtp_auth_code
